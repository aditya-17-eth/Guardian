{
  "name": "guardian",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx tsc -b && npx vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "vitest run src/contract",
    "compile:contract": "compact compile contracts/guardian.compact contracts/managed/guardian",
    "deploy:contract": "tsx scripts/deploy-contract.ts",
    "db:migrate": "supabase db push"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "2.5.0",
